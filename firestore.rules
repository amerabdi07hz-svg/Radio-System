rules_version = '2';

// ⚠️ هذا الملف غير موجود أصلاً في المشروع المرفوع.
// يجب نسخ محتواه ولصقه في: Firebase Console → Firestore Database → Rules
// ثم الضغط على "Publish". بدون هذا، فإن أي شخص يعرف رابط مشروعك على Firebase
// يمكنه قراءة/تعديل/حذف كل البيانات مباشرة إن كانت القاعدة على وضع Test Mode.

service cloud.firestore {
  match /databases/{database}/documents {

    // دالة مساعدة: هل المستخدم الحالي مسجّل دخول ولديه وثيقة في users؟
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() &&
             userDoc().data.role == 'مسؤول المنظومة';
    }

    function isReadOnly() {
      return isSignedIn() &&
             userDoc().data.permission == 'readonly';
    }

    // مجموعة المستخدمين: كل مستخدم مسجّل يمكنه قراءة القائمة (لعرض الأسماء)،
    // لكن الإنشاء/التعديل/الحذف للمدير فقط. لا يمكن لأي مستخدم تعديل صلاحياته بنفسه.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() && userId != request.auth.uid; // لا يحذف نفسه
    }

    // الأجهزة، المخزن، المشتريات: قراءة لأي مستخدم مسجّل دخول،
    // كتابة/تعديل فقط لمن ليس صلاحيته "readonly".
    match /devices/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isReadOnly();
      allow delete: if isSignedIn() && !isReadOnly();
    }

    match /store/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isReadOnly();
      allow delete: if isSignedIn() && !isReadOnly();
    }

    match /purchases/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isReadOnly();
      allow delete: if isSignedIn() && !isReadOnly();
    }

    // الأرشيف: القراءة للجميع، لكن الحذف النهائي للمدير فقط.
    match /archive/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isReadOnly();
      allow delete: if isAdmin();
    }

    // أي مسار غير مذكور أعلاه: ممنوع تمامًا افتراضيًا.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
